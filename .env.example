# Copy this to .env and fill in your values
# cp .env.example .env  (Mac/Linux)
# copy .env.example .env  (Windows)

# Application
APP_NAME="Smart Loan Processing System"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# Database - matches docker-compose.yml credentials
DATABASE_URL=postgresql+asyncpg://loanuser:loanpass@localhost:5432/loandb
DATABASE_URL_SYNC=postgresql://loanuser:loanpass@localhost:5432/loandb

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=loan_applications

# Groq - FREE key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-8b-8192

# JWT - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-256-bit-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Decision Engine Thresholds
SIMILARITY_THRESHOLD=0.75
CONFIDENCE_THRESHOLD=0.80
AUTO_APPROVE_MIN_CREDIT=700
AUTO_APPROVE_MAX_DTI=0.40
AUTO_APPROVE_MAX_LTI=5.0
AUTO_REJECT_MAX_CREDIT=600
AUTO_REJECT_MIN_DTI=0.65

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
